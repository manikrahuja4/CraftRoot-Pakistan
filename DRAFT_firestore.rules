rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'fatimakhanzada.paak@gmail.com'
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for Analytics
    function isValidAnalytics(data) {
      return data.keys().hasAll(['eventName', 'timestamp']) &&
             data.eventName is string && data.eventName.size() <= 100 &&
             data.timestamp is string && data.timestamp.size() <= 64;
    }

    // 1. Analytics Collection
    match /analytics/{eventId} {
      allow create: if isValidId(eventId) && isValidAnalytics(incoming());
      allow read: if isAdmin();
    }

    // 2. Admins Collection
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }
  }
}
